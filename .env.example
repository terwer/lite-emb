# ============================================================
# lite-emb 配置文件
# 复制此文件为 .env 并根据需要修改
# ============================================================

# -- 服务器配置 --
DEV_HOST=0.0.0.0
DEV_PORT=8000
WORKERS=1

# -- 模型配置 --
# 默认使用 all-MiniLM-L6-v2（80MB），也可以使用其他 HuggingFace 模型
# 例如: "all-minilm", "bge-m3", "BAAI/bge-micro"
MODEL_NAME=e5-small
MAX_BATCH_SIZE=32
MAX_SEQUENCE_LENGTH=512

# -- 预加载配置 --
# 是否在启动时预加载模型（true: 启动时加载，false: 首次请求时懒加载）
PRELOAD_MODEL=false
# 是否允许在请求中通过 model 参数切换模型
ALLOW_MODEL_SWITCH=false

# -- Embedding 配置 --
# 是否对输出向量进行 L2 归一化
EMBEDDING_NORMALIZE=true

# -- HuggingFace 配置 --
# HuggingFace 镜像地址（国内用户可设置 hf-mirror.com 加速下载）
HF_ENDPOINT=https://hf-mirror.com
# 是否启用 hf-transfer 加速下载
HF_HUB_ENABLE_HF_TRANSFER=true
# 离线模式（如果为 1，则不会从网络下载模型，仅使用本地缓存）
HF_HUB_OFFLINE=0

# -- 日志配置 --
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
